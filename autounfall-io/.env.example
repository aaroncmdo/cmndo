# autounfall.io — ENV-Template (WP-8 Go-Live).
# Live-Datei: /etc/autounfall/.env.local (root:root, chmod 600) — GETRENNT von
# Claimondos /etc/claimondo/.env.local. NUR au.io-Secrets, NICHT Claimondos
# Secrets mitnutzen (Standalone-Strategie).
#
# Next.js standalone liest .env.local aus dem cwd beim Server-Start (dotenv).
# Auf dem VPS also: /var/www/autounfall.io/.env.local → Symlink auf
# /etc/autounfall/.env.local (analog claimondo-v2).

# ── Site-Identität (Client-sichtbar, NEXT_PUBLIC_*) ──────────────────────────
NEXT_PUBLIC_SITE_URL=https://autounfall.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=autounfall.io

# au.io-eigene Kontaktdaten — OFFEN (Aaron): NICHT die kfzgutachter-Nummer
# 0221 25906530 / aaron.sprafke@claimondo.de (= Claimondo-Footprints, verknuepfen
# au.io oeffentlich mit Claimondo). Eigene au.io-Mail + -Nummer eintragen, sonst
# leer lassen (Impressum/DS zeigen dann den Platzhalter-Hinweis).
NEXT_PUBLIC_SITE_EMAIL=
NEXT_PUBLIC_SITE_PHONE=

# ── Supabase (WP-6 Lead-Form) ───────────────────────────────────────────────
# Geteiltes Backend (paizkjajbuxxksdoycev). NEXT_PUBLIC_SUPABASE_URL ist
# client-sichtbar; SUPABASE_SERVICE_ROLE_KEY ist SERVER-ONLY (niemals
# NEXT_PUBLIC_*!) — bypasst RLS, nur in der Server-Action genutzt. Erst noetig,
# sobald WP-6 (gutachter-finden) live ist; ohne den Key liefert das Formular
# einen graceful Soft-Error (kein Crash).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
