{
  "permissions": {
    "allow": [
      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__claude_ai_Notion__notion-update-page",
      "Bash(find 'c:/Users/Aaron Sprafke/stampit-app/stampit-app/claimondo-v2' -name *.tsx -not -path */node_modules/* -not -path */.next/*)",
      "Read(//temp/readonly/**)",
      "Read(//c/Users/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/hooks/update-session-marker.mjs start",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/hooks/update-session-marker.mjs prompt",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/hooks/check-umlauts.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/hooks/update-session-marker.mjs pre-bash",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/hooks/update-session-marker.mjs bash",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/hooks/update-session-marker.mjs edit",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/hooks/update-session-marker.mjs stop",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
