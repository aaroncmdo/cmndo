{
  "name": "@claimondo/baileys-worker",
  "version": "0.1.0",
  "private": true,
  "description": "AAR-898: WhatsApp-Worker auf Baileys-Web-Socket. Exposed eine interne HTTP-API auf Port 4001 fuer lookup + send. Laeuft als eigener PM2-Service auf dem VPS.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0",
    "express": "^5.1.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
