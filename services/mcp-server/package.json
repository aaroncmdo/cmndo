{
  "name": "claimondo-mcp-server",
  "version": "1.0.0",
  "private": true,
  "description": "MCP server exposing Claimondo's public read API (Kfz-Sachverstaendigen-Finder) as tools for LLM clients (Claude Desktop, Cline, Cursor).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claimondo-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "smoke": "node smoke.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
