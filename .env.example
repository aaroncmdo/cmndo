TWILIO_TPL_RECHNUNG_VERFUEGBAR=

# ─── Lexoffice ──────────────────────────────────────────
LEXOFFICE_API_KEY=

# ─── Google Ads ─────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=

# ─── Anthropic ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Linear (AAR-518 Support-Bot) ──────────────────────
# Personal API Key aus Linear Settings > API, Team-ID aus der Team-URL
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# ─── E2E Tests (KFZ-185) ───────────────────────────────
# Test-User Credentials (NICHT Production-User!)
TEST_ADMIN_EMAIL=test-admin@claimondo.de
TEST_ADMIN_PASSWORD=Test1234!
TEST_SV_EMAIL=test-sv@claimondo.de
TEST_SV_PASSWORD=Test1234!
# Optional: Vercel Preview URL statt localhost
PLAYWRIGHT_BASE_URL=http://localhost:3000
