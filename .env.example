# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ─────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Google SMTP (existing) ────────────────────────────
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=
GMAIL_SMTP_FROM=Claimondo <noreply@claimondo.de>

# ─── Sentry (KFZ-174) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Resend (KFZ-174) ──────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Claimondo <noreply@claimondo.de>
# Optional: Reply-To Adresse (default: gleich wie RESEND_FROM)
# RESEND_REPLY_TO=support@claimondo.de

# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cmndo.vercel.app
CRON_SECRET=
# BUG-105: HMAC-Secret fuer Realtime-Channel-Hashing (32 byte hex, z.B. openssl rand -hex 32)
SUPABASE_REALTIME_SECRET=

# ─── Google APIs ────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_VISION_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ─── Mapbox (AAR-380 Block G Field-Modus) ──────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Cardentity (Vorschaden-Recherche) ─────────────────
# Default-URL: https://api.cardentity.eu (EU-Region). Override hier
# wenn ihr eine andere Region nutzt.
CARDENTITY_API_URL=
CARDENTITY_CLIENT_ID=
CARDENTITY_CLIENT_SECRET=
# Optionaler Direct-Token-Override für Smoke-Tests bevor OAuth steht.
# Cardentity-Tokens sind nur 1h gültig — danach im Dashboard neuen Token
# generieren. Wenn gesetzt, springt getAccessToken() OAuth komplett aus.
CARDENTITY_ACCESS_TOKEN=

# ─── Twilio ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_WHATSAPP_FROM=

# Twilio WhatsApp Content Templates (nach Approval in Twilio Console)
# Format: HXxxxxxxxxxxx — leer lassen bis Templates genehmigt sind (Legacy-Fallback aktiv)
TWILIO_TPL_FALL_EROEFFNET=
TWILIO_TPL_FLOWLINK_VERSAND=
TWILIO_TPL_SV_BEAUFTRAGT=
TWILIO_TPL_TERMIN_BESTAETIGT=
