TWILIO_TPL_GUTACHTEN_FERTIG=
TWILIO_TPL_KANZLEI_UEBERGABE=
TWILIO_TPL_AS_GESENDET=
TWILIO_TPL_REGULIERUNG_ANGEKUENDIGT=
TWILIO_TPL_ZAHLUNG_EINGEGANGEN=
TWILIO_TPL_FALL_ABGESCHLOSSEN=
TWILIO_TPL_ESKALATION_TAG14=
TWILIO_TPL_ESKALATION_TAG28=
TWILIO_TPL_ESKALATION_TAG42=
TWILIO_TPL_CHAT_FALLBACK_KUNDE=
TWILIO_TPL_CHAT_FALLBACK_KB=
TWILIO_TPL_KUERZUNG_EINGETRAGEN=
